{
  "nodeTypes": [
    { "id": "selector", "label": "Selector", "description": "First succeeding child wins" },
    { "id": "sequence", "label": "Sequence", "description": "All children must succeed in order" },
    { "id": "conditionRef", "label": "Condition", "description": "Reference to a named condition definition" },
    { "id": "actionRef", "label": "Action", "description": "Reference to a named action definition" }
  ],
  "interruptTiers": [
    { "tier": 0, "label": "Critical", "description": "Life-threatening — always preempts" },
    { "tier": 1, "label": "Survival", "description": "Hunger, thirst, energy needs" },
    { "tier": 2, "label": "Discretionary", "description": "Mate, stalk — interruptible by survival" },
    { "tier": 3, "label": "Ambient", "description": "Default wander" }
  ],
  "thresholdKeys": [
    { "key": "thirstUrgent", "label": "Thirst urgent", "default": 30 },
    { "key": "thirstExit", "label": "Thirst exit", "default": 55 },
    { "key": "hungerUrgent", "label": "Hunger urgent", "default": 25 },
    { "key": "hungerGraze", "label": "Hunger graze entry", "default": 55 },
    { "key": "hungerExit", "label": "Hunger exit", "default": 65 },
    { "key": "hungerHunt", "label": "Hunger moderate hunt", "default": 75 },
    { "key": "energyUrgent", "label": "Energy urgent", "default": 12 },
    { "key": "restEnergy", "label": "Rest entry energy", "default": 18 },
    { "key": "energyExit", "label": "Energy exit", "default": 30 },
    { "key": "nightWanderRestEnergy", "label": "Night wander rest", "default": 75 },
    { "key": "mateHungerMin", "label": "Mate hunger min", "default": 45 },
    { "key": "mateThirstMin", "label": "Mate thirst min", "default": 40 },
    { "key": "mateEnergyMin", "label": "Mate energy min", "default": 45 }
  ],
  "conditionOps": [
    { "op": "hasThreat", "params": [] },
    { "op": "atWaterEdge", "params": [] },
    { "op": "thirstBelow", "params": [{ "name": "key", "type": "thresholdKey", "default": "thirstExit" }] },
    { "op": "thirstBelowWhileState", "params": [{ "name": "key", "type": "thresholdKey" }, { "name": "state", "type": "string" }] },
    { "op": "thirstBelowOrState", "params": [{ "name": "key", "type": "thresholdKey", "default": "thirstUrgent" }, { "name": "exitKey", "type": "thresholdKey", "default": "thirstExit" }, { "name": "state", "type": "string", "default": "thirst" }] },
    { "op": "hungerBelow", "params": [{ "name": "key", "type": "thresholdKey" }, { "name": "dietMax", "type": "int", "optional": true }] },
    { "op": "hungerBelowOrState", "params": [{ "name": "key", "type": "thresholdKey", "default": "hungerUrgent" }, { "name": "exitKey", "type": "thresholdKey", "default": "hungerExit" }, { "name": "diet", "type": "int", "optional": true }, { "name": "dietMax", "type": "int", "optional": true }, { "name": "dietMin", "type": "int", "optional": true }, { "name": "noPrey", "type": "bool", "optional": true }] },
    { "op": "hungerBelowNoPrey", "params": [{ "name": "key", "type": "thresholdKey" }, { "name": "diet", "type": "int", "optional": true }, { "name": "dietMin", "type": "int", "optional": true }] },
    { "op": "hungerBelowNoPreyOrState", "params": [{ "name": "key", "type": "thresholdKey", "default": "hungerUrgent" }, { "name": "exitKey", "type": "thresholdKey", "default": "hungerExit" }, { "name": "grazeKey", "type": "thresholdKey", "default": "hungerGraze" }, { "name": "dietMin", "type": "int", "optional": true }] },
    { "op": "hungerBelowWithPrey", "params": [{ "name": "key", "type": "thresholdKey" }, { "name": "dietMin", "type": "int", "optional": true }] },
    { "op": "hungerBelowWithPreyOrState", "params": [{ "name": "key", "type": "thresholdKey", "default": "hungerUrgent" }, { "name": "exitKey", "type": "thresholdKey", "default": "hungerExit" }, { "name": "grazeKey", "type": "thresholdKey", "default": "hungerGraze" }, { "name": "dietMin", "type": "int", "optional": true }] },
    { "op": "energyBelow", "params": [{ "name": "key", "type": "thresholdKey", "default": "restEnergy" }] },
    { "op": "energyBelowOrState", "params": [{ "name": "key", "type": "thresholdKey", "default": "energyUrgent" }, { "name": "exitKey", "type": "thresholdKey", "default": "energyExit" }, { "name": "state", "type": "string", "default": "rest" }] },
    { "op": "canMate", "params": [] },
    { "op": "nightWanderTired", "params": [] }
  ],
  "actionFields": [
    { "name": "label", "type": "string", "required": true },
    { "name": "state", "type": "string", "required": true },
    { "name": "goal", "type": "string", "required": true },
    { "name": "speedMult", "type": "number", "optional": true },
    { "name": "interruptTier", "type": "int", "optional": true },
    { "name": "minCommitSec", "type": "number", "optional": true },
    { "name": "drinkAtShore", "type": "bool", "optional": true }
  ]
}
